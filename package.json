{
  "name": "myshowcasespace",
  "version": "0.1.0",
  "description": "MVP SaaS platform for artist showcase sites",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "predev": "npm run prisma:generate",
    "dev": "tsx watch src/index.ts",
    "predev:api": "npm run prisma:generate",
    "dev:api": "tsx watch src/index.ts",
    "dev:web": "npm --prefix frontend run dev",
    "build:web": "npm --prefix frontend run build",
    "build:vercel": "npm run build:web",
    "build:all": "npm run build && npm run build:web",
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run prisma:generate",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx scripts/ensure-db.ts && prisma migrate dev",
    "prisma:deploy": "tsx scripts/ensure-db.ts && prisma migrate deploy",
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "saas",
    "fastify",
    "prisma",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.3.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "nanoid": "^5.1.7",
    "uploadthing": "^7.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
