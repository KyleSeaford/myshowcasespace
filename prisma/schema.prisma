generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DomainType {
  SUBDOMAIN
  CUSTOM
}

enum BillingStatus {
  INACTIVE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum CheckoutStatus {
  PENDING
  COMPLETED
  EXPIRED
}

enum TenantMemberRole {
  OWNER
  MEMBER
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  passwordHash           String
  passwordChangeRequired Boolean            @default(false)
  legalAcceptedAt        DateTime?
  legalAcceptedVersion   String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  sessions               Session[]
  tenants                Tenant[]
  memberships            TenantMember[]
  sentTenantInvitations  TenantInvitation[] @relation("TenantInvitationInviter")
  receivedInvitations    TenantInvitation[] @relation("TenantInvitationInvitee")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Plan {
  id           String   @id
  name         String
  pieceLimit   Int?
  monthlyPrice Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants                Tenant[]
  billingCheckoutSession BillingCheckoutSession[]
}

model Tenant {
  id           String    @id @default(cuid())
  ownerUserId  String
  planId       String
  name         String
  slug         String    @unique
  bio          String?
  contactEmail String
  socialLinks  String?
  theme        String?
  themeId      String    @default("default")
  themeLocked  Boolean   @default(false)
  tenantCode   String    @unique
  published    Boolean   @default(false)
  publishedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner            User                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  plan             Plan                     @relation(fields: [planId], references: [id])
  pieces           Piece[]
  domains          Domain[]
  apiKeys          ApiKey[]
  billingAccount   BillingAccount?
  checkoutSessions BillingCheckoutSession[]
  members          TenantMember[]
  invitations      TenantInvitation[]

  @@index([ownerUserId])
  @@index([planId])
}

model TenantMember {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantMemberRole @default(MEMBER)
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([role])
}

model TenantInvitation {
  id              String    @id @default(cuid())
  tenantId        String
  email           String
  invitedByUserId String
  invitedUserId   String?
  temporaryAccount Boolean  @default(false)
  emailSentAt     DateTime?
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime?

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedByUser User   @relation("TenantInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedUser   User?  @relation("TenantInvitationInvitee", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@index([invitedUserId])
}

model Piece {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  slug        String
  description String?
  year        Int?
  category    String?
  images      String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([published])
}

model Domain {
  id         String     @id @default(cuid())
  tenantId   String
  type       DomainType
  hostname   String     @unique
  verified   Boolean    @default(false)
  isPrimary  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  keyHash    String    @unique
  keyPreview String
  label      String?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model BillingAccount {
  id                   String        @id @default(cuid())
  tenantId             String        @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               BillingStatus @default(INACTIVE)
  currentPeriodEnd     DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BillingCheckoutSession {
  id              String         @id @default(cuid())
  tenantId        String
  targetPlanId    String
  provider        String
  providerRef     String
  status          CheckoutStatus @default(PENDING)
  checkoutUrl     String
  createdAt       DateTime       @default(now())
  completedAt     DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetPlan Plan   @relation(fields: [targetPlanId], references: [id])

  @@index([tenantId])
  @@index([status])
}
